{
  "version": 2,
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/service/:slug",
      "destination": "/templates/service-template"
    },
    {
      "source": "/location/:slug",
      "destination": "/templates/location-template"
    },
    {
      "source": "/emergency",
      "destination": "/templates/emergency-landing"
    }
  ]
}
