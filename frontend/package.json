{
  "name": "hvac-frontend-system",
  "version": "1.0.0",
  "description": "Shared frontend system, templates, and components for HVAC website",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint assets/js/**/*.js",
    "lint:css": "stylelint assets/css/**/*.css",
    "validate": "npm run lint && npm run lint:css && npm run test"
  },
  "keywords": [
    "frontend",
    "hvac",
    "templates",
    "conversion"
  ],
  "jest": {
    "testEnvironment": "jsdom",
    "collectCoverageFrom": [
      "assets/js/**/*.js",
      "!assets/js/**/*.test.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ]
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "@testing-library/dom": "^9.0.0",
    "jsdom": "^20.0.0",
    "eslint": "^8.0.0",
    "stylelint": "^14.0.0"
  }
}
