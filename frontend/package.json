{
  "name": "hvac-frontend-system",
  "version": "1.0.0",
  "description": "Shared frontend system, templates, and components for HVAC website",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint assets/js/**/*.js",
    "lint:css": "stylelint assets/css/**/*.css",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "validate:js:syntax": "node --check assets/js/system.js && node --check api/*.js lib/*.js lib/tools/*.js lib/adapters/*.js",
    "validate:templates": "node scripts/validate-templates.mjs",
    "validate:tracking-docs": "node scripts/validate-tracking-docs.mjs",
    "build": "npm run validate:templates && npm run validate:js:syntax && npm run validate:tracking-docs",
    "validate": "npm run lint && npm run lint:css && npm run typecheck && npm run test -- --runInBand && npm run build"
  },
  "keywords": [
    "frontend",
    "hvac",
    "templates",
    "conversion"
  ],
  "jest": {
    "testEnvironment": "jsdom",
    "collectCoverageFrom": [
      "assets/js/**/*.js",
      "!assets/js/**/*.test.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ]
  },
  "devDependencies": {
    "@testing-library/dom": "^9.0.0",
    "@types/node": "^22.15.29",
    "eslint": "^8.0.0",
    "http-server": "^14.1.1",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jsdom": "^20.0.0",
    "nodemailer": "^6.9.0",
    "stylelint": "^14.0.0",
    "stylelint-config-standard": "^29.0.0",
    "typescript": "^5.8.3"
  }
}
