# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.  Set to * to allow all (dev only).
ALLOWED_ORIGINS=http://localhost:8080,https://potter-perrone.vercel.app

# ─── Service area ─────────────────────────────────────────────────────────────
# Comma-separated ZIP codes served by this business.
# Defaults to the Syracuse-area list when not set.
SERVICE_AREA_ZIPS=13201,13202,13203,13204,13205,13206,13207,13208,13209,13210,13211,13212,13214,13215,13219,13220,13221,13224,13244,13290,13027,13031,13057,13066,13088,13090,13116,13120,13122,13132,13152

# Comma-separated city names served (lowercase, optional).
SERVICE_AREA_CITIES=syracuse,liverpool,cicero,camillus,east syracuse,dewitt,salina,clay,geddes,solvay,fayetteville,manlius,minoa

# ─── Business location (for weather context) ──────────────────────────────────
BUSINESS_LAT=43.0481
BUSINESS_LNG=-76.1474

# ─── AI provider (optional) ───────────────────────────────────────────────────
# Leave blank to use rule-based policy routing only.
# Set these when you are ready to wire a real LLM for classification or chat.
AI_PROVIDER_URL=
AI_PROVIDER_KEY=

# ─── Lead delivery: webhook ───────────────────────────────────────────────────
# POST destination for new leads and handoffs.  Works with Zapier, Make, n8n,
# your own CRM webhook, or any HTTPS endpoint that accepts JSON.
WEBHOOK_URL=
# Optional HMAC-SHA256 secret — the adapter sets X-Signature-256 header.
WEBHOOK_SECRET=

# ─── Lead delivery: email (SMTP fallback) ─────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
LEAD_TO_EMAIL=
LEAD_FROM_EMAIL=

# ─── AirNow API key ────────────────────────────────────────────────────────────
# Free registration at https://docs.airnowapi.org/
# Used to include air quality context with lead payloads.
AIRNOW_API_KEY=
